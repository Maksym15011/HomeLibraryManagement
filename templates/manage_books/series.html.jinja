{% extends "base.html.jinja" %}

{% block content %}

<div class="max-w-5xl mx-auto">

<div class="bg-white rounded-xl shadow-lg overflow-hidden">

    <div class="bg-slate-800 text-white p-8">

        <h1 class="text-4xl font-bold">
            {{ series.name }}
        </h1>

        {% if series.description %}
        <p class="mt-3 text-slate-300">
            {{ series.description }}
        </p>
        {% endif %}

    </div>

    <div class="p-8">

        <h2 class="text-xl font-semibold border-b pb-2 mb-4">
            Informacje o serii
        </h2>

        <div class="grid md:grid-cols-2 gap-4">

            <div>
                <strong>Nazwa:</strong>
                {{ series.name }}
            </div>

            <div>
                <strong>Liczba książek:</strong>
                {{ series.book_set.count }}
            </div>

        </div>

    </div>

    <div class="px-8 pb-8">

        <h2 class="text-xl font-semibold border-b pb-2 mb-4">
            Książki należące do serii
        </h2>

        <div class="grid md:grid-cols-2 gap-4">

            {% for book in series.book_set.all|dictsort:"publication_date" %}

                <a
                    href="{% url 'book' book.id %}"
                    class="block border rounded-lg p-4 hover:bg-slate-50 transition"
                >

                    <div class="font-semibold">
                        {{ book.title }}
                    </div>

                    <div class="text-sm text-gray-500 mt-1">
                        {{ book.publication_date }}
                    </div>

                </a>

            {% empty %}

                <p>Brak książek w tej serii.</p>

            {% endfor %}

        </div>

    </div>

</div>

</div>

{% endblock %}
