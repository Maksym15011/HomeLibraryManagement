{% extends "base.html.jinja" %}

{% block content %}

<style>
    input,
    select,
    textarea {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        margin-top: 4px;
    }

    input:focus,
    select:focus,
    textarea:focus {
        outline: none;
        border-color: #334155;
        box-shadow: 0 0 0 2px rgba(51, 65, 85, 0.2);
    }

    select[multiple] {
        min-height: 120px;
    }

    .helptext {
        color: #64748b;
        font-size: 0.875rem;
    }
</style>

<div class="max-w-4xl mx-auto">


<div class="bg-white rounded-2xl shadow-xl overflow-hidden">

    <div class="bg-slate-800 text-white p-8">

        <h1 class="text-4xl font-bold">
            {{ title }}
        </h1>

        <p class="mt-2 text-slate-300">
            Dodaj nową książkę do biblioteki
        </p>

    </div>

    <div class="p-8">

        <form method="post">

            {% csrf_token %}

            <div class="space-y-6">

                {% for field in form %}

                    <div>

                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            {{ field.label }}
                        </label>

                        {{ field }}

                        {% if field.errors %}
                            <p class="text-red-600 text-sm mt-1">
                                {{ field.errors|striptags }}
                            </p>
                        {% endif %}

                    </div>

                {% endfor %}

            </div>

            <div class="flex justify-end gap-3 mt-8">

                <a
                    href="/"
                    class="px-5 py-2 border rounded-lg hover:bg-gray-100 transition"
                >
                    Anuluj
                </a>

                <button
                    type="submit"
                    class="bg-slate-800 text-white px-6 py-2 rounded-lg hover:bg-slate-700 transition"
                >
                    Zapisz książkę
                </button>

            </div>

        </form>

    </div>

</div>

</div>

{% endblock %}
