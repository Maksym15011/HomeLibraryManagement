{% extends "base.html.jinja" %}

{% block content %}
<div class="max-w-5xl mx-auto">

<div class="bg-white rounded-xl shadow-lg overflow-hidden">

    <div class="bg-slate-800 text-white p-8">

        <h1 class="text-4xl font-bold">
            {{ book.title }}
        </h1>

        <p class="mt-2 text-slate-300">
            {{ book.author }}
        </p>

    </div>

    <div class="grid md:grid-cols-2 gap-6 p-8">

        <div class="space-y-3">

            <h2 class="text-xl font-semibold border-b pb-2">
                Informacje podstawowe
            </h2>

            <p><strong>ISBN:</strong> {{ book.isbn }}</p>

            <p>
                <strong>Data publikacji:</strong>
                {{ book.publication_date }}
            </p>

            <p>
                <strong>Liczba stron:</strong>
                {{ book.pages }}
            </p>

            <p>
                <strong>Typ okładki:</strong>
                {{ book.get_cover_display }}
            </p>

            <p>
                <strong>Język:</strong>
                {{ book.get_language_display }}
            </p>

        </div>

        <div class="space-y-3">

            <h2 class="text-xl font-semibold border-b pb-2">
                Status
            </h2>

            <p>
                <strong>Przeczytana:</strong>

                {% if book.is_read %}
                    ✅ Tak
                {% else %}
                    ❌ Nie
                {% endif %}
            </p>

            <p>
                <strong>Ulubiona:</strong>

                {% if book.is_favorite %}
                    ⭐ Tak
                {% else %}
                    Nie
                {% endif %}
            </p>

        </div>

        {% if user.is_authenticated %}

<div class="flex gap-3 mt-4">

    <form
        method="post"
        action="{% url 'toggle_favorite' book.id %}"
    >
        {% csrf_token %}

        <button
            type="submit"
            class="bg-yellow-500 text-white px-4 py-2 rounded-lg hover:bg-yellow-600"
        >
            {% if book.is_favorite %}
                Usuń z ulubionych
            {% else %}
                Dodaj do ulubionych
            {% endif %}
        </button>


    </form>

    <form
        method="post"
        action="{% url 'toggle_read' book.id %}"
    >
        {% csrf_token %}

        <button
            type="submit"
            class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700"
        >
            {% if book.is_read %}
                Oznacz jako nieprzeczytaną
            {% else %}
                Oznacz jako przeczytaną
            {% endif %}
        </button>

    </form>

    <a
    href="{% url 'edit_book' book.id %}"
    class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 flex items-center"
>
    Edytuj książkę
</a>

<form
    method="post"
    action="{% url 'delete_book' book.id %}"
    onsubmit="return confirm('Czy na pewno chcesz usunąć tę książkę?')"
>
    {% csrf_token %}

    <button
        type="submit"
        class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700"
    >
        Usuń książkę
    </button>
</form>

</div>

{% endif %}

    </div>

    <div class="px-8 pb-8">

        <h2 class="text-xl font-semibold mb-3">
            Autorzy
        </h2>

        <div class="flex flex-wrap gap-2">

            {% for author in book.authors.all %}

                <a
                    href="{% url 'author' author.id %}"
                    class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full"
                >
                    {{ author.first_name }}
                    {{ author.last_name }}
                </a>

            {% endfor %}

        </div>

    </div>

    <div class="px-8 pb-8">

        <h2 class="text-xl font-semibold mb-3">
            Wydawnictwo
        </h2>

        <a
            href="{% url 'publisher' book.publisher.id %}"
            class="text-blue-600 hover:underline"
        >
            {{ book.publisher.name }}
        </a>

    </div>

    {% if book.series %}

    <div class="px-8 pb-8">

        <h2 class="text-xl font-semibold mb-3">
            Seria
        </h2>

        <a
            href="{% url 'series' book.series.id %}"
            class="text-blue-600 hover:underline"
        >
            {{ book.series.name }}
        </a>

    </div>

    {% endif %}

    <div class="px-8 pb-8">

        <h2 class="text-xl font-semibold mb-3">
            Gatunki
        </h2>

        <div class="flex flex-wrap gap-2">

            {% for genre in book.genres.all %}
                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full">
                    {{ genre.name }}
                </span>
            {% empty %}
                Brak gatunków
            {% endfor %}

        </div>

    </div>

    <div class="px-8 pb-8">

        <h2 class="text-xl font-semibold mb-3">
            Tematy
        </h2>

        <div class="flex flex-wrap gap-2">

            {% for topic in book.topics.all %}
                <span class="bg-purple-100 text-purple-700 px-3 py-1 rounded-full">
                    {{ topic.name }}
                </span>
            {% empty %}
                Brak tematów
            {% endfor %}

        </div>

    </div>

</div>


</div>

<div class="px-8 pb-8">

    <h2 class="text-xl font-semibold mb-4">
        Notatki
    </h2>

    {% for note in book.note_set.all %}

        <div class="bg-slate-50 border rounded-lg p-4 mb-3">

            <div class="flex justify-between">

                <span class="font-semibold">
                    {{ note.user.username }}
                </span>

                <span class="text-sm text-gray-500">
                    {{ note.created_at|date:"d.m.Y H:i" }}
                </span>

            </div>

            <p class="mt-3">
                {{ note.content }}
            </p>

        </div>

    {% empty %}

        <p class="text-gray-500">
            Brak notatek.
        </p>

    {% endfor %}

</div>

{% if user.is_authenticated %}

<div class="px-8 pb-8">

    <h2 class="text-xl font-semibold mb-4">
        Dodaj notatkę
    </h2>

    <form
        method="post"
        action="{% url 'add_note' book.id %}"
    >

        {% csrf_token %}

        <textarea
            name="content"
            rows="4"
            required
            class="w-full border rounded-lg p-3"
            placeholder="Wpisz treść notatki..."
        ></textarea>

        <button
            type="submit"
            class="mt-3 bg-slate-800 text-white px-5 py-2 rounded-lg hover:bg-slate-700"
        >
            Dodaj notatkę
        </button>

    </form>

</div>

{% endif %}

{% endblock %}
