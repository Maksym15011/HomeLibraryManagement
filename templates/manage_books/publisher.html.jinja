{% extends "base.html.jinja" %}

{% block content %}

<div class="max-w-5xl mx-auto">

<div class="bg-white rounded-xl shadow-lg overflow-hidden">

    <div class="bg-slate-800 text-white p-8">

        <h1 class="text-4xl font-bold">
            {{ publisher.name }}
        </h1>

    </div>

    <div class="p-8">

        <h2 class="text-xl font-semibold border-b pb-2 mb-4">
            Informacje o wydawnictwie
        </h2>

        <div class="grid md:grid-cols-2 gap-4">

            <div>
                <strong>Kraj:</strong>
                {{ publisher.country }}
            </div>

            <div>
                <strong>Rok założenia:</strong>
                {{ publisher.founded_year }}
            </div>

            <div>
                <strong>Strona WWW:</strong>

                {% if publisher.website %}
                    <a
                        href="{{ publisher.website }}"
                        target="_blank"
                        class="text-blue-600 hover:underline"
                    >
                        Odwiedź stronę
                    </a>
                {% else %}
                    Brak
                {% endif %}
            </div>

            <div>
                <strong>Email:</strong>

                {% if publisher.email %}
                    <a
                        href="mailto:{{ publisher.email }}"
                        class="text-blue-600 hover:underline"
                    >
                        {{ publisher.email }}
                    </a>
                {% else %}
                    Brak
                {% endif %}
            </div>

        </div>

    </div>

    <div class="px-8 pb-8">

        <h2 class="text-xl font-semibold border-b pb-2 mb-4">
            Książki wydawnictwa
        </h2>

        <div class="grid md:grid-cols-2 gap-4">

            {% for book in publisher.book_set.all %}

                <a
                    href="{% url 'book' book.id %}"
                    class="block border rounded-lg p-4 hover:bg-slate-50 transition"
                >
                    <div class="font-semibold">
                        {{ book.title }}
                    </div>

                    <div class="text-sm text-gray-500 mt-1">
                        {{ book.publication_date }}
                    </div>
                </a>

            {% empty %}

                <p>Brak książek.</p>

            {% endfor %}

        </div>

    </div>

</div>

</div>

{% endblock %}
