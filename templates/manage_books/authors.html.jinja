<!doctype html>
{% extends "base.html.jinja" %}
{% block title %}Lista autorów{% endblock %}
{% block content %}
<section class="max-w-6xl mx-auto w-full py-10 px-4">

    <div class="flex flex-col bg-white rounded-lg shadow-md p-4">
        <h3 class="text-md font-semibold mb-2">Autorzy</h3>
        {% for author in authors %}
            <div class="border-b py-2">
                <a href="{% url 'author' author.id %}" class="text-blue-500 hover:underline">{{ author.first_name }} {{ author.last_name }}</a>
                <p class="text-sm text-gray-600">{{ author.biography }}</p>
            </div> 
            {% empty %}
            <p class="text-gray-600">No books available.</p>
            {% endfor %}
    </div>
</section>
{% endblock %}